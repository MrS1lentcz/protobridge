# =============================================================================
# protobridge – Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# --- gRPC service addresses (required) ---
PROTOBRIDGE_TASK_SERVICE_ADDR=localhost:50051
PROTOBRIDGE_AUTH_SERVICE_ADDR=localhost:50051

# --- HTTP server ---
PROTOBRIDGE_PORT=8080

# --- HTTP server timeouts (defense against Slowloris + resource leaks) ---
# PROTOBRIDGE_READ_HEADER_TIMEOUT=10s
# PROTOBRIDGE_READ_TIMEOUT=30s
# PROTOBRIDGE_WRITE_TIMEOUT=0s           # 0 = disabled (default, required for WS/SSE)
# PROTOBRIDGE_IDLE_TIMEOUT=120s          # keep-alive idle timeout
# PROTOBRIDGE_MAX_HEADER_BYTES=1048576   # 1 MiB

# --- TLS (HTTPS) ---
# PROTOBRIDGE_TLS_CERT=/certs/cert.pem
# PROTOBRIDGE_TLS_KEY=/certs/key.pem
# PROTOBRIDGE_TLS_SERVER_NAME=api.example.com

# --- Per-service gRPC TLS ---
# PROTOBRIDGE_TASK_SERVICE_TLS=true

# --- CORS ---
# PROTOBRIDGE_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# PROTOBRIDGE_CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# PROTOBRIDGE_CORS_HEADERS=Content-Type,Authorization
# PROTOBRIDGE_CORS_MAX_AGE=86400

# --- Observability ---
# PROTOBRIDGE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# PROTOBRIDGE_OTEL_ENDPOINT=otel-collector:4317
# PROTOBRIDGE_OTEL_SERVICE_NAME=protobridge
# PROTOBRIDGE_METRICS_PORT=9090

# --- gRPC client options ---
# Global options applied to all services.
# PROTOBRIDGE_GRPC_OPTIONS=max_recv_msg_size=16mb,keepalive_time=30s,keepalive_timeout=10s
#
# Per-service overrides (applied on top of global):
# PROTOBRIDGE_TASK_SERVICE_GRPC_OPTIONS=max_recv_msg_size=64mb
